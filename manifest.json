{
  "manifest_version": 3,
  "name": "Chat Lens",
  "version": "1.0.0",
  "description": "Detects confidence amplification in ChatGPT responses. Scores each message with a real-time Confidence Amplification Score (CAS).",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Chat Lens",
    "default_icon": {
      "16": "icons/chatlens16.png",
      "32": "icons/ChatLens32.png",
      "48": "icons/chatlens48.png",
      "128": "icons/ChatLens128.png"
    }
  },
  "icons": {
    "16": "icons/chatlens16.png",
    "32": "icons/ChatLens32.png",
    "48": "icons/chatlens48.png",
    "128": "icons/ChatLens128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*"
      ],
      "js": ["content-script.js"],
      "css": ["lens.css"],
      "run_at": "document_idle"
    }
  ]
}
