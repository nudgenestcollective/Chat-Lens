{
  "manifest_version": 3,
  "name": "Nudge Lens",
  "version": "1.0.0",
  "description": "Detects epistemic risk in ChatGPT and Gemini responses. Green, amber, or red trust rating helps you think critically about AI.",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Chat Lens",
    "default_icon": {
      "16": "icons/chatlens16.png",
      "32": "icons/ChatLens32.png",
      "48": "icons/chatlens48.png",
      "128": "icons/ChatLens128.png"
    }
  },
  "icons": {
    "16": "icons/chatlens16.png",
    "32": "icons/ChatLens32.png",
    "48": "icons/chatlens48.png",
    "128": "icons/ChatLens128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*"
      ],
      "js": [
        "content-script.js"
      ],
      "css": [
        "lens.css"
      ],
      "run_at": "document_idle"
    }
  ]
}